{
  "entities": {
    "User": {
      "title": "User",
      "description": "Regular user of the Lost & Found app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "nearestStationId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Admin": {
      "title": "Police Admin",
      "description": "Police station administrator",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "stationName": { "type": "string" },
        "email": { "type": "string" },
        "location": { "type": "object" },
        "contactDetails": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["uid", "stationName", "email", "role"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Lost or Found item report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["lost", "found"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "location": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "under-review", "resolved", "rejected"] },
        "assignedStationId": { "type": "string" },
        "adminMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "description", "status", "assignedStationId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Alert for users or admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Target user ID (or 'admin' for all admins)" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["status_change", "new_report"] },
        "complaintId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of users and admins"
    },
    "complaints": {
      "schema": "Complaint",
      "description": "Collection of lost and found reports"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of alerts for users and admins"
    }
  }
}
